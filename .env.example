AGENTFORGE_RUNTIME_MODE=development
AWS_REGION=us-east-1

# Required in production. Enable the selected model in Amazon Bedrock first.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
FLEETFIX_CASE_TABLE=fleetfix-cases-production
FLEETFIX_JWT_ISSUER=https://issuer.example.com
FLEETFIX_JWT_AUDIENCE=fleetfix-api
FLEETFIX_JWT_ROLE_CLAIM=custom:role

# Approved HTTPS services or AgentCore Gateway targets. Secrets belong in a workload identity or secret manager, never here.
FLEETFIX_VEHICLE_CONTEXT_URL=https://gateway.example.com/fleet/vehicle-context
FLEETFIX_PARTS_AVAILABILITY_URL=https://gateway.example.com/fleet/parts-availability
FLEETFIX_WORK_ORDER_URL=https://gateway.example.com/fleet/work-orders
